#!/usr/bin/env ruby

# puts "\n== Updating NPM =="
# system "npm upgrade", exception: true

if system("which mise")
  puts "\n== Updating Mise and ruby-build =="
  system "mise cache clean && mise ls-remote ruby", exception: true
end

puts "\n== Updating Rubygems and system Bundler =="
system "gem update --system && gem update bundler", exception: true

puts "\n== Updating Gemfile Bundler =="
# output looks like "bundler (2.7.2, 2.7.1, 2.7.0, ...)
bundler_version = `gem search '^bundler$' --all`.match(/bundler \(([\d.]*),/)[1]
raise "Problem fetching bundler version" unless bundler_version
system "bundle update --bundler #{bundler_version}", exception: true

puts "\n== Updating Gems =="
system "bundle update --all", exception: true
